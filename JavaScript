const RingMeter = ({value, max=10, color, size=64, label}) => {
  const r = (size-8)/2, circ = 2*Math.PI*r, dash = circ*(value/max);
  return (
    <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:4}}>
      <svg width={size} height={size}>
        <circle cx={size/2} cy={size/2} r={r} fill="none" stroke="var(--border)" strokeWidth={4}/>
        <circle cx={size/2} cy={size/2} r={r} fill="none" stroke={color} strokeWidth={4}
          strokeDasharray={`${dash} ${circ}`} strokeLinecap="round"
          transform={`rotate(-90 ${size/2} ${size/2})`}/>
        <text x={size/2} y={size/2+5} textAnchor="middle" fill={color} fontSize={14} fontWeight={700} fontFamily="'DM Mono',monospace">{value}</text>
      </svg>
      <span style={{fontSize:10, color:"var(--muted)", letterSpacing:.5}}>{label}</span>
    </div>
  );
};

const BarChart = ({data, height=120}) => {
  const max = Math.max(...data.map(d=>d.work+d.study+d.sport+d.home+d.relax));
  const cats = ["work","study","sport","home","relax"];
  return (
    <div style={{display:"flex",alignItems:"flex-end",gap:6,height}}>
      {data.map((d,i)=>{
        const total = cats.reduce((s,c)=>s+(d[c]||0),0);
        return (
          <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:3}}>
            <div style={{width:"100%",display:"flex",flexDirection:"column-reverse",borderRadius:4,overflow:"hidden",height:height-20}}>
              {cats.map(c=>{
                const h = ((d[c]||0)/max)*(height-20);
                return h>0 ? <div key={c} style={{width:"100%",height:h,background:catColor(c),opacity:.85}}/> : null;
              })}
            </div>
            <span style={{fontSize:9,color:"var(--muted)"}}>{d.day}</span>
          </div>
        );
      })}
    </div>
  );
};

const LineChart = ({data, color, height=80}) => {
  const w=280, h=height, pad=8;
  const max=Math.max(...data), min=Math.min(...data);
  const pts = data.map((v,i)=>({
    x: pad + i*(w-2*pad)/(data.length-1),
    y: h - pad - (v-min)/(max-min||1)*(h-2*pad)
  }));
  const path = pts.map((p,i)=>`${i===0?"M":"L"}${p.x},${p.y}`).join(" ");
  const area = path + ` L${pts[pts.length-1].x},${h} L${pts[0].x},${h} Z`;
  return (
    <svg width="100%" viewBox={`0 0 ${w} ${h}`} style={{overflow:"visible"}}>
      <defs>
        <linearGradient id={`lg-${color.replace("#","")}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={color} stopOpacity=".35"/>
          <stop offset="100%" stopColor={color} stopOpacity="0"/>
        </linearGradient>
      </defs>
      <path d={area} fill={`url(#lg-${color.replace("#","")})`}/>
      <path d={path} fill="none" stroke={color} strokeWidth={2} strokeLinecap="round"/>
      {pts.map((p,i)=><circle key={i} cx={p.x} cy={p.y} r={3} fill={color}/>)}
    </svg>
  );
};

// ── Timer Component ───────────────────────────────────────────────────────────
const TimerPanel = () => {
  const [running, setRunning] = useState(false);
  const [elapsed, setElapsed] = useState(0);
  const [cat, setCat] = useState("work");
  const [logs, setLogs] = useState([
    {cat:"work",dur:5400,label:"Ochtend sprint"},
    {cat:"study",dur:2700,label:"Econometrics"},
  ]);
  const [manHours, setManHours] = useState("");
  const [manCat, setManCat] = useState("work");
  const [manLabel, setManLabel] = useState("");
  const ref = useRef(null);

  useEffect(()=>{
    if(running){ ref.current = setInterval(()=>setElapsed(e=>e+1),1000); }
    else clearInterval(ref.current);
    return ()=>clearInterval(ref.current);
  },[running]);

  const stop = () => {
    if(elapsed>0) setLogs(l=>[{cat,dur:elapsed,label:"Timer sessie"},...l]);
    setRunning(false); setElapsed(0);
  };

  const addManual = () => {
    const h = parseFloat(manHours);
    if(!h||h<=0) return;
    setLogs(l=>[{cat:manCat,dur:Math.round(h*3600),label:manLabel||"Handmatige invoer"},...l]);
    setManHours(""); setManLabel("");
  };

  return (
    <div style={{display:"grid",gap:20}}>
      {/* Timer */}
      <Card>
        <div style={{fontSize:11,color:"var(--muted)",letterSpacing:1,marginBottom:16}}>TIMER MODUS</div>
        <div style={{
          fontFamily:"'DM Mono',monospace", fontSize:64, fontWeight:500,
          color: running?"var(--gold)":"var(--text)",
          textAlign:"center", letterSpacing:4, marginBottom:20,
          animation: running?"timerPulse 2s infinite":"none"
        }}>{fmt(elapsed)}</div>

        {/* Category picker */}
        <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:20,justifyContent:"center"}}>
          {CATEGORIES.map(c=>(
            <button key={c.id} onClick={()=>setCat(c.id)} style={{
              background: cat===c.id ? c.color+"33" : "var(--surface)",
              border:`1px solid ${cat===c.id?c.color:"var(--border)"}`,
              color: cat===c.id ? c.color : "var(--muted)",
              borderRadius:8, padding:"6px 12px", cursor:"pointer",
              fontFamily:"'DM Sans',sans-serif", fontSize:12, fontWeight:500,
              transition:"all .2s"
            }}>{c.icon} {c.label}</button>
          ))}
        </div>

        <div style={{display:"flex",gap:10,justifyContent:"center"}}>
          {!running
            ? <GoldBtn onClick={()=>setRunning(true)} style={{animation:"pulse-gold 2s infinite"}}>▶ Start</GoldBtn>
            : <>
                <GhostBtn onClick={()=>setRunning(false)}>⏸ Pauze</GhostBtn>
                <GoldBtn onClick={stop}>⏹ Stop & Opslaan</GoldBtn>
              </>
          }
        </div>
      </Card>

      {/* Manual */}
      <Card>
        <div style={{fontSize:11,color:"var(--muted)",letterSpacing:1,marginBottom:16}}>HANDMATIGE INVOER</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:12}}>
          <input value={manHours} onChange={e=>setManHours(e.target.value)} type="number" min="0" step="0.25"
            placeholder="Uren (bijv. 1.5)" style={inputStyle}/>
          <input value={manLabel} onChange={e=>setManLabel(e.target.value)}
            placeholder="Omschrijving" style={inputStyle}/>
        </div>
        <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:12}}>
          {CATEGORIES.map(c=>(
            <button key={c.id} onClick={()=>setManCat(c.id)} style={{
              background: manCat===c.id ? c.color+"33" : "var(--surface)",
              border:`1px solid ${manCat===c.id?c.color:"var(--border)"}`,
              color: manCat===c.id ? c.color : "var(--muted)",
              borderRadius:8, padding:"5px 10px", cursor:"pointer",
              fontFamily:"'DM Sans',sans-serif", fontSize:11, transition:"all .2s"
            }}>{c.icon} {c.label}</button>
          ))}
        </div>
        <GoldBtn onClick={addManual} small>+ Toevoegen</GoldBtn>
      </Card>

      {/* Log */}
      <Card>
        <div style={{fontSize:11,color:"var(--muted)",letterSpacing:1,marginBottom:16}}>VANDAAG GELOGD</div>
        <div style={{display:"flex",flexDirection:"column",gap:8}}>
          {logs.map((l,i)=>(
            <div key={i} style={{
              display:"flex",alignItems:"center",gap:12,padding:"10px 14px",
              background:"var(--surface)",borderRadius:10,
              borderLeft:`3px solid ${catColor(l.cat)}`
            }}>
              <span style={{fontSize:18}}>{catIcon(l.cat)}</span>
              <div style={{flex:1}}>
                <div style={{fontSize:13,fontWeight:500}}>{l.label}</div>
                <div style={{fontSize:11,color:"var(--muted)"}}>{CATEGORIES.find(c=>c.id===l.cat)?.label}</div>
              </div>
              <div style={{fontFamily:"'DM Mono',monospace",fontSize:13,color:"var(--gold)"}}>{fmt(l.dur)}</div>
            </div>
          ))}
        </div>
      </Card>
