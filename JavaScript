// ── Todo Component ────────────────────────────────────────────────────────────
const TodoPanel = () => {
  const [todos, setTodos] = useState(MOCK_TODOS);
  const [title, setTitle] = useState("");
  const [pri, setPri] = useState("mid");
  const [cat, setCat] = useState("work");
  const [est, setEst] = useState("");

  const toggle = (id) => setTodos(t=>t.map(x=>x.id===id?{...x,done:!x.done}:x));
  const add = () => {
    if(!title.trim()) return;
    setTodos(t=>[{id:Date.now(),title,priority:pri,cat,est:parseInt(est)||30,done:false},...t]);
    setTitle(""); setEst("");
  };

  const priColor = {high:"var(--red)",mid:"var(--amber)",low:"var(--muted)"};
  const priLabel = {high:"Hoog",mid:"Midden",low:"Laag"};

  const done = todos.filter(t=>t.done).length;

  return (
    <div style={{display:"grid",gap:20}}>
      <Card>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
          <div style={{fontSize:11,color:"var(--muted)",letterSpacing:1}}>TAKEN VANDAAG</div>
          <Badge color="var(--gold)">{done}/{todos.length} klaar</Badge>
        </div>

        {/* Progress bar */}
        <div style={{background:"var(--border)",borderRadius:4,height:4,marginBottom:20}}>
          <div style={{background:"var(--gold)",height:4,borderRadius:4,width:`${(done/todos.length)*100}%`,transition:"width .4s"}}/>
        </div>

        {/* Add task */}
        <div style={{background:"var(--surface)",borderRadius:12,padding:14,marginBottom:16}}>
          <input value={title} onChange={e=>setTitle(e.target.value)} placeholder="Nieuwe taak..."
            style={{...inputStyle, marginBottom:10}}
            onKeyDown={e=>e.key==="Enter"&&add()}/>
          <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:10}}>
            {["high","mid","low"].map(p=>(
              <button key={p} onClick={()=>setPri(p)} style={{
                background: pri===p?priColor[p]+"22":"var(--card)",
                border:`1px solid ${pri===p?priColor[p]:"var(--border)"}`,
                color: pri===p?priColor[p]:"var(--muted)",
                borderRadius:6, padding:"4px 10px", cursor:"pointer",
                fontFamily:"'DM Sans',sans-serif", fontSize:11, transition:"all .2s"
              }}>{priLabel[p]}</button>
            ))}
            <input value={est} onChange={e=>setEst(e.target.value)} type="number" placeholder="Min."
              style={{...inputStyle, width:70}}/>
          </div>
          <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:10}}>
            {CATEGORIES.map(c=>(
              <button key={c.id} onClick={()=>setCat(c.id)} style={{
                background: cat===c.id?c.color+"22":"var(--card)",
                border:`1px solid ${cat===c.id?c.color:"var(--border)"}`,
                color: cat===c.id?c.color:"var(--muted)",
                borderRadius:6, padding:"4px 8px", cursor:"pointer",
                fontFamily:"'DM Sans',sans-serif", fontSize:11, transition:"all .2s"
              }}>{c.icon}</button>
            ))}
          </div>
          <GoldBtn onClick={add} small>+ Taak toevoegen</GoldBtn>
        </div>

        {/* List */}
        <div style={{display:"flex",flexDirection:"column",gap:6}}>
          {todos.map(t=>(
            <div key={t.id} onClick={()=>toggle(t.id)} style={{
              display:"flex",alignItems:"center",gap:12,padding:"12px 14px",
              background:"var(--surface)", borderRadius:10, cursor:"pointer",
              borderLeft:`3px solid ${t.done?"var(--border)":catColor(t.cat)}`,
              opacity: t.done ? .5 : 1, transition:"all .2s"
            }}>
              <div style={{
                width:18,height:18,borderRadius:"50%",flexShrink:0,
                border:`2px solid ${t.done?"var(--green)":"var(--border)"}`,
                background: t.done?"var(--green)":"transparent",
