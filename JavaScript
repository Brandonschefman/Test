// ── AI Panel ──────────────────────────────────────────────────────────────────
const AIPanel = () => {
  const [loading, setLoading] = useState(false);
  const [schedule, setSchedule] = useState(null);
  const [insight, setInsight] = useState(null);
  const [question, setQuestion] = useState("");
  const [answer, setAnswer] = useState("");
  const [chatLoading, setChatLoading] = useState(false);

  const generateSchedule = async () => {
    setLoading(true);
    setSchedule(null);
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body: JSON.stringify({
          model:"claude-sonnet-4-20250514",
          max_tokens:1000,
          messages:[{
            role:"user",
            content:`Je bent een persoonlijke productiviteitscoach. Genereer een optimaal dagschema op basis van deze data:
- Beste focustijden: 09:00-11:30 en 13:00-15:00
- Sport verhoogt productiviteit 25%
- Gemiddelde energie: 7.5/10 's ochtends, daalt naar 6 na 15:00
- Optimale werkblokken: 90 minuten met 15 min pauze
- Top productieve dag: woensdag (na sport)

Geef een concreet dagschema met tijdblokken. Reageer in het Nederlands, kort en krachtig. Gebruik emoji per item. Max 200 woorden.`
          }]
        })
      });
      const data = await res.json();
      const text = data.content?.find(b=>b.type==="text")?.text || "Geen data beschikbaar.";
      setSchedule(text);
    } catch(e) {
      setSchedule("Er is iets misgegaan. Probeer opnieuw.");
    }
    setLoading(false);
  };

  const getInsight = async () => {
    setLoading(true);
    setInsight(null);
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body: JSON.stringify({
          model:"claude-sonnet-4-20250514",
          max_tokens:600,
          messages:[{
            role:"user",
            content:`Analyseer deze productiviteitsdata van de afgelopen week en geef 3 concrete inzichten in het Nederlands:
Maandag: werk 6.5u, energie 7, focus 8
Dinsdag: werk 5u, energie 6, focus 6 (geen sport)
Woensdag: werk 7u, energie 8, focus 9 (sport)
Donderdag: werk 4u, studie 3u, energie 9, focus 8 (sport)
Vrijdag: werk 6u, energie 7, focus 7
Zaterdag: ontspanning 4u, energie 8, focus 6
Zondag: rust, energie 6

Geef 3 korte, actionable inzichten. Elke inzicht max 2 zinnen. Gebruik ✦ als bullet.`
          }]
        })
      });
      const data = await res.json();
      const text = data.content?.find(b=>b.type==="text")?.text || "Geen inzichten beschikbaar.";
      setInsight(text);
    } catch(e) {
      setInsight("Er is iets misgegaan.");
    }
    setLoading(false);
  };

  const askCoach = async () => {
    if(!question.trim()) return;
    setChatLoading(true);
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body: JSON.stringify({
          model:"claude-sonnet-4-20250514",
          max_tokens:400,
          messages:[{
            role:"user",
            content:`Je bent een persoonlijke AI productiviteitscoach. De gebruiker vraagt: "${question}"
Geef een kort, praktisch antwoord in het Nederlands. Max 100 woorden. Wees direct en concreet.`
          }]
        })
      });
      const data = await res.json();
      const text = data.content?.find(b=>b.type==="text")?.text || "Geen antwoord.";
      setAnswer(text);
    } catch(e) {
      setAnswer("Fout bij ophalen antwoord.");
    }
    setChatLoading(false);
  };

  const catColor2 = (type) => CATEGORIES.find(c=>c.id===type)?.color ?? "#888";

  return (
    <div style={{display:"grid",gap:20}}>
      {/* Header */}
      <div style={{
        padding:"24px 28px", background:"linear-gradient(135deg, var(--gold)18, var(--amber)08)",
        border:"1px solid var(--gold-dim)", borderRadius:16, animation:"fadeUp .4s ease"
      }}>
        <div style={{fontFamily:"'Playfair Display',serif",fontSize:24,fontWeight:700,marginBottom:8}}>
          ✦ AI Ritme Coach
        </div>
        <div style={{fontSize:13,color:"var(--muted)",lineHeight:1.6}}>
          Jouw persoonlijke AI-coach analyseert je gedragspatronen en genereert optimale dagstructuren op basis van je energie, focus en activiteiten.
        </div>
      </div>

      {/* Actions */}
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
        <GoldBtn onClick={generateSchedule} style={{width:"100%"}}>
          {loading?"⏳ Laden...":"🗓 Genereer Dagschema"}
        </GoldBtn>
        <GhostBtn onClick={getInsight} style={{width:"100%",borderColor:"var(--gold-dim)",color:"var(--gold)"}}>
          {loading?"⏳ Laden...":"🔍 Analyseer Week"}
        </GhostBtn>
      </div>

      {/* Schedule result */}
      {(loading && !schedule && !insight) && (
        <Card>
          <div style={{display:"flex",alignItems:"center",gap:12,color:"var(--muted)"}}>
            <div style={{width:18,height:18,border:"2px solid var(--gold)",borderTopColor:"transparent",borderRadius:"50%",animation:"spin 1s linear infinite"}}/>
            AI analyseert jouw patronen…
          </div>
        </Card>
      )}

      {schedule && (
        <Card style={{borderColor:"var(--gold-dim)"}}>
          <div style={{fontSize:11,color:"var(--gold)",letterSpacing:1,marginBottom:12}}>✦ JOUW OPTIMALE DAGSCHEMA</div>
          <div style={{fontSize:13,lineHeight:1.8,color:"var(--text)",whiteSpace:"pre-line"}}>{schedule}</div>
        </Card>
      )}

      {insight && (
        <Card style={{borderColor:"var(--amber)44"}}>
          <div style={{fontSize:11,color:"var(--amber)",letterSpacing:1,marginBottom:12}}>✦ AI INZICHTEN</div>
          <div style={{fontSize:13,lineHeight:1.8,color:"var(--text)",whiteSpace:"pre-line"}}>{insight}</div>
        </Card>
      )}

      {/* Static schedule preview */}
      <Card>
        <div style={{fontSize:11,color:"var(--muted)",letterSpacing:1,marginBottom:16}}>VOORBEELDSCHEMA — WOENSDAG</div>
        <div style={{display:"flex",flexDirection:"column",gap:6}}>
          {MOCK_AI_SCHEDULE.map((s,i)=>(
            <div key={i} style={{
              display:"flex",alignItems:"center",gap:12,padding:"10px 14px",
              background:"var(--surface)",borderRadius:10,
              borderLeft:`3px solid ${catColor2(s.type)}`
            }}>
              <div style={{fontFamily:"'DM Mono',monospace",fontSize:11,color:"var(--muted)",width:42,flexShrink:0}}>{s.time}</div>
              <div style={{flex:1,fontSize:13}}>{s.label}</div>
              <Badge color={catColor2(s.type)}>{s.dur}m</Badge>
            </div>
          ))}
        </div>
      </Card>

      {/* Ask coach */}
      <Card>
        <div style={{fontSize:11,color:"var(--muted)",letterSpacing:1,marginBottom:16}}>VRAAG AAN JE COACH</div>
        <div style={{display:"flex",gap:10,marginBottom:12}}>
          <input value={question} onChange={e=>setQuestion(e.target.value)}
            placeholder="Bijv. Hoe verbeter ik mijn ochtendroutine?"
            style={{...inputStyle,flex:1}}
            onKeyDown={e=>e.key==="Enter"&&askCoach()}/>
          <GoldBtn onClick={askCoach} small>{chatLoading?"…":"Vraag"}</GoldBtn>
        </div>
        {chatLoading && <div style={{fontSize:12,color:"var(--muted)",display:"flex",gap:8,alignItems:"center"}}>
          <div style={{width:12,height:12,border:"2px solid var(--gold)",borderTopColor:"transparent",borderRadius:"50%",animation:"spin 1s linear infinite"}}/>
          Coach denkt na…
        </div>}
        {answer && (
          <div style={{
            padding:"14px 16px",background:"var(--gold)0a",
            border:"1px solid var(--gold-dim)",borderRadius:10,
            fontSize:13,lineHeight:1.7,color:"var(--text)"
          }}>{answer}</div>
        )}
      </Card>
    </div>
  );
};

